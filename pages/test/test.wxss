.test-page {
  padding-bottom: calc(72rpx + env(safe-area-inset-bottom));
}

.nav-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 900;
  padding: 18rpx 0 28rpx;
}

.form-card {
  padding: 26rpx;
}

.section-label {
  font-size: 30rpx;
  font-weight: 900;
  margin-bottom: 20rpx;
}

.field-row {
  display: grid;
  grid-template-columns: 180rpx 1fr;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.field-label {
  color: #111111;
  font-size: 28rpx;
  font-weight: 700;
}

.input,
.picker-value {
  display: flex;
  align-items: center;
  height: 76rpx;
  box-sizing: border-box;
  padding: 0 22rpx;
  border: 2rpx solid #b8b8b8;
  border-radius: 12rpx;
  background: #ffffff;
  color: #111111;
  font-size: 28rpx;
  line-height: normal;
}

.placeholder {
  color: #888888;
}

.progress-block {
  margin: 28rpx 0 18rpx;
}

.progress-head {
  display: flex;
  justify-content: space-between;
  color: #111111;
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.progress-track {
  height: 16rpx;
  border: 2rpx solid #111111;
  border-radius: 999rpx;
  overflow: hidden;
  background: #ffffff;
}

.progress-fill {
  height: 100%;
  background: #111111;
}

.question-card {
  padding: 32rpx;
}

.question-type {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: #111111;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.question-title {
  margin-top: 26rpx;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.5;
}

.answer-list {
  margin-top: 32rpx;
}

.answer-item {
  min-height: 76rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-sizing: border-box;
  padding: 16rpx 18rpx;
  border: 2rpx solid #b8b8b8;
  border-radius: 12rpx;
  background: #ffffff;
  font-size: 28rpx;
}

.answer-item + .answer-item {
  margin-top: 16rpx;
}

.answer-item.active {
  border-color: #111111;
  background: #f6f6f3;
}

.answer-code {
  width: 42rpx;
  height: 42rpx;
  border-radius: 8rpx;
  background: #111111;
  color: #ffffff;
  line-height: 42rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 900;
}

.answer-radio {
  display: none;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.nav-button {
  width: 100%;
  min-width: 0;
  margin: 0;
  padding: 0 16rpx;
  text-align: center;
}
