.analyzing-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.analysis-card {
  width: 100%;
  box-sizing: border-box;
  padding: 34rpx 30rpx 36rpx;
}

.top-kicker {
  padding-bottom: 18rpx;
  border-bottom: 3rpx solid #111111;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.title {
  margin-top: 40rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: 900;
}

.subtitle {
  min-height: 42rpx;
  margin-top: 16rpx;
  text-align: center;
  color: #333333;
  font-size: 28rpx;
  font-weight: 700;
}

.analysis-visual {
  display: flex;
  justify-content: center;
  margin: 42rpx 0 40rpx;
}

.scan-frame {
  position: relative;
  width: 360rpx;
  height: 300rpx;
  overflow: hidden;
}

.corner {
  position: absolute;
  width: 54rpx;
  height: 54rpx;
  border-color: #111111;
  border-style: solid;
}

.corner-lt {
  left: 6rpx;
  top: 6rpx;
  border-width: 5rpx 0 0 5rpx;
}

.corner-rt {
  right: 6rpx;
  top: 6rpx;
  border-width: 5rpx 5rpx 0 0;
}

.corner-lb {
  left: 6rpx;
  bottom: 6rpx;
  border-width: 0 0 5rpx 5rpx;
}

.corner-rb {
  right: 6rpx;
  bottom: 6rpx;
  border-width: 0 5rpx 5rpx 0;
}

.scan-line {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  top: 32rpx;
  height: 5rpx;
  background: #111111;
  animation: scanMove 1.4s ease-in-out infinite;
}

.radar-shape {
  position: absolute;
  left: 90rpx;
  top: 58rpx;
  width: 180rpx;
  height: 180rpx;
  transform: rotate(30deg);
}

.radar-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  border: 3rpx solid #111111;
  transform: translate(-50%, -50%) rotate(30deg);
  clip-path: polygon(50% 0, 93% 25%, 93% 75%, 50% 100%, 7% 75%, 7% 25%);
}

.r1 {
  width: 180rpx;
  height: 180rpx;
}

.r2 {
  width: 124rpx;
  height: 124rpx;
  opacity: 0.65;
}

.r3 {
  width: 68rpx;
  height: 68rpx;
  opacity: 0.45;
}

.radar-axis {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 3rpx;
  height: 178rpx;
  background: #111111;
  transform-origin: center;
  opacity: 0.35;
}

.a1 {
  transform: translate(-50%, -50%);
}

.a2 {
  transform: translate(-50%, -50%) rotate(60deg);
}

.a3 {
  transform: translate(-50%, -50%) rotate(120deg);
}

.radar-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 72rpx;
  height: 72rpx;
  background: #111111;
  transform: translate(-50%, -50%) rotate(30deg);
  clip-path: polygon(50% 0, 93% 25%, 93% 75%, 50% 100%, 7% 75%, 7% 25%);
  animation: pulse 1.2s ease-in-out infinite;
}

.spark {
  position: absolute;
  font-size: 28rpx;
  font-weight: 900;
  animation: blink 1.6s ease-in-out infinite;
}

.s1 {
  left: 46rpx;
  top: 104rpx;
}

.s2 {
  right: 44rpx;
  top: 88rpx;
  animation-delay: 0.25s;
}

.s3 {
  right: 66rpx;
  bottom: 58rpx;
  animation-delay: 0.45s;
}

.progress-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 900;
}

.progress-track {
  height: 18rpx;
  border: 3rpx solid #111111;
  border-radius: 999rpx;
  overflow: hidden;
  background: #ffffff;
}

.progress-fill {
  height: 100%;
  background: #111111;
  transition: width 120ms linear;
}

.step-list {
  margin-top: 34rpx;
}

.step-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 44rpx;
  color: #777777;
  font-size: 26rpx;
  font-weight: 700;
}

.step-item + .step-item {
  margin-top: 16rpx;
}

.step-item.active {
  color: #111111;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  box-sizing: border-box;
  border: 3rpx solid #111111;
  border-radius: 50%;
  background: #ffffff;
}

.step-item.active .step-dot {
  background: #111111;
}

@keyframes scanMove {
  0% {
    transform: translateY(0);
    opacity: 0.2;
  }
  45% {
    opacity: 1;
  }
  100% {
    transform: translateY(220rpx);
    opacity: 0.2;
  }
}

@keyframes pulse {
  0%,
  100% {
    transform: translate(-50%, -50%) rotate(30deg) scale(0.9);
    opacity: 0.72;
  }
  50% {
    transform: translate(-50%, -50%) rotate(30deg) scale(1.06);
    opacity: 1;
  }
}

@keyframes blink {
  0%,
  100% {
    opacity: 0.25;
  }
  50% {
    opacity: 1;
  }
}
